-- Auto Click Minigame Race Button (Fixed via getconnections)
local function autoClickRaceButton()
    local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
    if not playerGui then return end
    
    local minigameRace = playerGui:FindFirstChild("MinigameRace")
    if not minigameRace then return end
    
    local function findButton(parent)
        if parent:IsA("TextButton") or parent:IsA("ImageButton") then return parent end
        for _, child in ipairs(parent:GetChildren()) do
            local btn = findButton(child)
            if btn then return btn end
        end
        return nil
    end

    local button = findButton(minigameRace)
    if not button then return end

    if getconnections then
        local activated = getconnections(button.Activated)
        if #activated > 0 then
            for _, conn in ipairs(activated) do conn:Fire() end return
        end
        local mouseClick = getconnections(button.MouseButton1Click)
        if #mouseClick > 0 then
            for _, conn in ipairs(mouseClick) do conn:Fire() end return
        end
    end

    if button.AbsoluteSize.X > 0 and button.AbsoluteSize.Y > 0 then
        local VirtualInputManager = game:GetService("VirtualInputManager")
        local center = button.AbsolutePosition + (button.AbsoluteSize / 2)
        VirtualInputManager:SendMouseButtonEvent(center.X, center.Y, 0, true, game, 0)
        task.wait(0.05)
        VirtualInputManager:SendMouseButtonEvent(center.X, center.Y, 0, false, game, 0)
    end
end

