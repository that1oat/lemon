--// Disable 3D Rendering to Reduce Lag
local function enable3DRendering()
    if originalStreamingMode ~= nil then
        workspace.Streaming.StreamingMode = originalStreamingMode
        originalStreamingMode = nil
    end
    
    -- Re-enable the camera if it was disabled
    local camera = workspace.CurrentCamera
    if camera then
        camera.CameraType = Enum.CameraType.Custom
    end
end

local function disable3DRendering()
    if originalStreamingMode == nil then
        originalStreamingMode = workspace.Streaming.StreamingMode
    end
    
    -- Set streaming mode to manual to stop rendering distant objects
    workspace.Streaming.StreamingMode = Enum.StreamingMode.Manual
    
    -- Force set camera to a fixed position or disable certain rendering features
    local camera = workspace.CurrentCamera
    if camera then
        -- This reduces rendering load significantly
        camera.CameraType = Enum.CameraType.Scriptable
    end
    
    -- Clear streaming grid to stop loading new chunks
    workspace.Streaming.TargetRadius = 0
end

-- Function to toggle 3D rendering
local function toggle3DRendering(disable)
    if disable then
        pcall(function()
            disable3DRendering()
            
            -- Optional: Hide terrain and certain parts to improve performance
            local terrain = workspace:FindFirstChild("Terrain")
            if terrain then
                terrain.WaterReflectance = 0
                terrain.WaterWaveSize = 0
                terrain.WaterTransparency = 1
            end
            
            -- Reduce part rendering quality
            workspace.GlobalRenderingQualityLevel = 1
        end)
    else
        pcall(function()
            enable3DRendering()
            
            -- Restore terrain settings
            local terrain = workspace:FindFirstChild("Terrain")
            if terrain then
                terrain.WaterReflectance = 0.5
                terrain.WaterWaveSize = 0.5
                terrain.WaterTransparency = 0.5
            end
            
            -- Restore rendering quality
            workspace.GlobalRenderingQualityLevel = 2
        end)
    end
end

-- Cleanup function when script ends
local function cleanupRendering()
    if Disable3DRendering then
        enable3DRendering()
    end
end

