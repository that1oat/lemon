local function teleportToBase()
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")

    if not hrp or not userTycoon then
        return false
    end

    -- Try a few common spawn/base parts first
    local target =
        userTycoon:FindFirstChild("SpawnLocation", true)
        or userTycoon:FindFirstChild("Spawn", true)
        or userTycoon:FindFirstChild("ClaimPart", true)

    if target and target:IsA("BasePart") then
        hrp.CFrame = target.CFrame + Vector3.new(0, 5, 0)
    else
        -- fallback to tycoon center
        hrp.CFrame = userTycoon:GetPivot() + Vector3.new(0, 5, 0)
    end

    return true
end

