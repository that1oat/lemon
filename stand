-- FASTER Auto Upgrade. The old version scanned thousands of tycoon objects EVERY
-- frame and fired 100 server calls per machine per frame (huge FPS/network drag).
-- Now we cache the Upgrade remotes, refreshing only every 3s (to catch tycoon
-- rebuilds), and each machine just climbs from its last reached level upward,
-- stopping as soon as the server rejects (can't afford / maxed). Once maxed it
-- costs ~nothing. The level tracker resets on refresh so it re-climbs as cash grows.
local upgradeRemotes  = {}
local upgradeLevel    = {}   -- [remote] = highest level reached this scan window
local lastUpgradeScan = 0

local function refreshUpgradeRemotes()
    upgradeRemotes = {}
    upgradeLevel   = {}
    local purchases = userTycoon:FindFirstChild("Purchases")
    if not purchases then return end
    for _, obj in ipairs(purchases:GetDescendants()) do
        if obj:IsA("RemoteFunction") and obj.Name == "Upgrade" then
            upgradeRemotes[#upgradeRemotes + 1] = obj
        end
    end
end

task.spawn(function()
    while true do
        task.wait(0.25)

        if AutoUpgrade then
            if tick() - lastUpgradeScan > 3 then
                refreshUpgradeRemotes()
                lastUpgradeScan = tick()
            end

            for _, remote in ipairs(upgradeRemotes) do
                if remote.Parent then
                    local lvl = (upgradeLevel[remote] or 0) + 1
                    while lvl <= 100 do
                        local ok, res = pcall(function() return remote:InvokeServer(lvl) end)
                        if (not ok) or res == false then break end
                        upgradeLevel[remote] = lvl
                        stats.upgrades = stats.upgrades + 1
                        lvl = lvl + 1
                    end
                end
            end
        end
    end
end)

-- NEW: Auto Accept Phone Offers
-- Listens for when a phone offer appears and automatically accepts it
local function setupPhoneOfferAutoAccept()
    -- Find all tycoons (we need to monitor offers from all, but prioritize owned)
    local function acceptOfferFromTycoon(tycoon)
        local phoneOffer = tycoon:FindFirstChild("Remotes") and 
                           tycoon.Remotes:FindFirstChild("PhoneOffer")
        if phoneOffer then
            pcall(function()
                phoneOffer:FireServer("Accept")
                stats.phone = stats.phone + 1
            end)
        end
    end

    -- Check all tycoons periodically (phone offers can appear in any tycoon)
    task.spawn(function()
        while true do
            task.wait(0.5) -- Check every half second for phone offers
            
            if AutoAcceptPhone then
                -- First check the player's owned tycoon
                if userTycoon then
                    acceptOfferFromTycoon(userTycoon)
                end
                
                -- Also check other tycoons (some phone offers might be global)
                for _, tycoon in pairs(workspace:GetChildren()) do
                    if tycoon:IsA("Folder") and tycoon.Name:match("Tycoon%d") then
                        if tycoon ~= userTycoon then -- Avoid double-checking owned
                            acceptOfferFromTycoon(tycoon)
                        end
                    end
                end
            end
        end
    end)
    
    -- Also listen for when PhoneOffer remote appears (real-time detection)
    local function onRemoteAdded(remote)
        if AutoAcceptPhone and remote.Name == "PhoneOffer" and remote:IsA("RemoteFunction") then
            pcall(function()
                remote:FireServer("Accept")
                stats.phone = stats.phone + 1
            end)
        end
    end
    
    -- Monitor all tycoons for new remotes
    for _, tycoon in pairs(workspace:GetChildren()) do
        if tycoon:IsA("Folder") and tycoon.Name:match("Tycoon%d") then
            local remotes = tycoon:FindFirstChild("Remotes")
            if remotes then
                remotes.ChildAdded:Connect(onRemoteAdded)
            end
        end
    end
end

-- Initialize the phone offer auto-accept system
setupPhoneOfferAutoAccept()

